# ===========================================
# LIBRARY MANAGEMENT SYSTEM - DEVELOPMENT CONFIG
# ===========================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/library_management_dev
MONGODB_TEST_URI=mongodb://localhost:27017/library_management_test

# JWT Configuration - CHANGE THESE IN PRODUCTION!
JWT_SECRET=LibraryManagement_SuperSecret_JWT_Key_2024_Development_Only
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=LibraryManagement_RefreshToken_Secret_2024_Dev
JWT_REFRESH_EXPIRE=30d

# Email Configuration (for notifications)
# For development, you can use Gmail with App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=noreply@library.com

# Fine Configuration
FINE_PER_DAY=2.00
MAX_RENEWAL_COUNT=2
LOAN_PERIOD_DAYS=14

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Security Configuration
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Configuration
ADMIN_EMAIL=admin@library.com
ADMIN_PASSWORD=Admin@123456

# Development Specific
DEBUG=true
LOG_LEVEL=debug
