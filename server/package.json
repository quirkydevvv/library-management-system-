{
  "name": "library-management-backend",
  "version": "1.0.0",
  "description": "Backend API for MERN Stack Library Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:auth": "jest tests/auth.test.js",
    "test:books": "jest tests/books.test.js",
    "test:users": "jest tests/users.test.js",
    "test:transactions": "jest tests/transactions.test.js",
    "test:reservations": "jest tests/reservations.test.js",
    "test:categories": "jest tests/categories.test.js",
    "test:integration": "jest tests/integration.test.js",
    "test:runner": "node tests/run-tests.js",
    "test:runner:coverage": "node tests/run-tests.js --coverage",
    "seed": "node scripts/seedData.js seed",
    "seed:clear": "node scripts/seedData.js clear"
  },
  "keywords": [
    "library",
    "management",
    "mern",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Library Management Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "dotenv": "^16.3.1",
    "nodemailer": "^6.9.4",
    "multer": "^1.4.5-lts.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.2",
    "supertest": "^6.3.3",
    "mongodb-memory-server": "^8.15.1",
    "eslint": "^8.47.0",
    "prettier": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
